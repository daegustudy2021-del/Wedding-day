
Bu premium style, countdown, Google/Yandex map va musiqa bilan bo‘ladi.

index.html ni ochib eski kodni o‘chirib, mana buni qo‘ying:

<!DOCTYPE html>
<html lang="uz">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Shahbos & Zilola</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;600&family=Great+Vibes&display=swap" rel="stylesheet">
<style>
*{
margin:0;
padding:0;
box-sizing:border-box;
}
body{
background:#f7f1e8;
font-family:'Cormorant Garamond', serif;
color:#4b3425;
overflow-x:hidden;
}
.hero{
min-height:100vh;
padding:40px 20px;
text-align:center;
background:
linear-gradient(rgba(247,241,232,0.82), rgba(247,241,232,0.88)),
url('https://images.unsplash.com/photo-1519741497674-611481863552?q=80&w=1200&auto=format&fit=crop');
background-size:cover;
background-position:center;
}
.top-text{
font-size:24px;
margin-top:30px;
opacity:0.8;
}
.names{
font-family:'Great Vibes', cursive;
font-size:72px;
margin-top:40px;
color:#7a4d32;
line-height:1.2;
}
.date{
font-size:30px;
margin-top:20px;
}
.place{
font-size:44px;
margin-top:25px;
font-weight:600;
letter-spacing:3px;
}
.main-photo{
width:90%;
max-width:420px;
margin-top:40px;
border-radius:25px;
box-shadow:0 15px 40px rgba(0,0,0,0.2);
}
.text{
width:90%;
max-width:700px;
margin:40px auto;
font-size:30px;
line-height:1.7;
}
.countdown-title{
font-size:34px;
margin-top:40px;
}
.countdown{
display:flex;
justify-content:center;
gap:15px;
flex-wrap:wrap;
margin-top:30px;
}
.box{
background:white;
padding:20px;
width:120px;
border-radius:20px;
box-shadow:0 10px 25px rgba(0,0,0,0.08);
}
.box h2{
font-size:42px;
color:#7a4d32;
}
.box p{
font-size:22px;
}
.btn{
display:block;
width:320px;
max-width:90%;
margin:20px auto;
padding:18px;
background:#7a4d32;
color:white;
text-decoration:none;
border-radius:20px;
font-size:24px;
transition:0.3s;
}
.btn:hover{
transform:scale(1.03);
}
.gallery{
padding:60px 20px;
text-align:center;
}
.gallery-title{
font-size:50px;
margin-bottom:40px;
font-family:'Great Vibes', cursive;
}
.photos{
display:flex;
flex-wrap:wrap;
justify-content:center;
gap:20px;
}
.photos img{
width:320px;
max-width:90%;
border-radius:25px;
box-shadow:0 10px 30px rgba(0,0,0,0.15);
}
.music{
margin-top:50px;
font-size:28px;
}
.footer{
padding:50px 20px;
text-align:center;
font-size:34px;
font-family:'Great Vibes', cursive;
}
audio{
margin-top:20px;
width:320px;
max-width:90%;
}
@media(max-width:600px){
.names{
font-size:54px;
}
.place{
font-size:32px;
}
.text{
font-size:24px;
}
}
</style>
</head>
<body>
<section class="hero">
<div class="top-text">
Bizning eng go'zal kunimizga taklif qilamiz
</div>
<div class="names">
Shahbos <br> & <br> Zilola
</div>
<div class="date">
15 Iyul 2026 | Soat 18:00
</div>
<div class="place">
MUHTASHAM
</div>
<img class="main-photo"
src="https://i.ibb.co/6g3L9QJ/couple.jpg">
<div class="text">
Muhabbat ila boshlangan hayotimizning
eng quvonchli kunida siz azizlarni kutib qolamiz ❤️
</div>
<div class="countdown-title">
To'y boshlanishiga:
</div>
<div class="countdown">
<div class="box">
<h2 id="days">00</h2>
<p>Kun</p>
</div>
<div class="box">
<h2 id="hours">00</h2>
<p>Soat</p>
</div>
<div class="box">
<h2 id="minutes">00</h2>
<p>Daqiqa</p>
</div>
<div class="box">
<h2 id="seconds">00</h2>
<p>Soniya</p>
</div>
</div>
<a class="btn"
href="https://maps.app.goo.gl/ZEhNRR5kc5GCcaJ4A?g_st=ic">
📍 Google Map orqali borish
</a>
<a class="btn"
href="https://yandex.uz/maps/org/124765896085?si=cg08vmzwdpg4jj6bbddqqpu744">
📍 Yandex Map orqali borish
</a>
<div class="music">
🎵 Dilnoz — Baxtlimiz taronasi
</div>
<audio controls autoplay loop>
<source src="music.mp3" type="audio/mpeg">
</audio>
</section>
<section class="gallery">
<div class="gallery-title">
Bizning suratlarimiz
</div>
<div class="photos">
<img src="https://i.ibb.co/0jQ2J4n/photo1.jpg">
<img src="https://i.ibb.co/W3K6w1D/photo2.jpg">
<img src="https://i.ibb.co/X2Jq5gL/photo3.jpg">
</div>
</section>
<div class="footer">
Sizni to'yimizda kutib qolamiz ❤️
</div>
<script>
const weddingDate =
new Date("2026-07-15T18:00:00").getTime();
setInterval(function(){
const now = new Date().getTime();
const distance = weddingDate - now;
const days =
Math.floor(distance / (1000*60*60*24));
const hours =
Math.floor((distance % (1000*60*60*24))
/ (1000*60*60));
const minutes =
Math.floor((distance % (1000*60*60))
/ (1000*60));
const seconds =
Math.floor((distance % (1000*60))
/ 1000);
document.getElementById("days").innerHTML = days;
document.getElementById("hours").innerHTML = hours;
document.getElementById("minutes").innerHTML = minutes;
document.getElementById("seconds").innerHTML = seconds;
},1000);
</script>
</body>
</html>
